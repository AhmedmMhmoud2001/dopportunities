generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  passwordHash String
  name         String?
  role         String    @default("user") // user | admin
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  contactRequests ContactRequest[]
}

model Page {
  id        Int      @id @default(autoincrement())
  slug      String   @unique // services, faq, about, contact
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Blog {
  id          Int      @id @default(autoincrement())
  title       String
  author      String?
  publishedAt DateTime?
  content     String   @db.Text
  slug        String   @unique
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Faq {
  id        Int      @id @default(autoincrement())
  question  String
  answer    String   @db.Text
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id        Int      @id @default(autoincrement())
  title     String
  slug      String   @unique
  description String @db.Text
  imageUrl  String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Testimonial {
  id        Int      @id @default(autoincrement())
  name      String
  quote     String?
  text      String   @db.Text
  imageUrl  String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// عنوان ووصف قسم «آراء العملاء» في الموقع (صف واحد)
model TestimonialsSection {
  id                 Int      @id @default(autoincrement())
  sectionTitle       String   @db.VarChar(500)
  sectionDescription String   @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model ContactRequest {
  id             Int       @id @default(autoincrement())
  trackingCode   String    @unique
  userId         Int?
  user           User?    @relation(fields: [userId], references: [id])
  firstName      String
  secondName     String
  phoneNumber    String
  activity       String
  status         String   @default("pending") // pending | processing | done | rejected
  notes          String?  @db.Text
  seenByAdminAt  DateTime? // null = admin has not acknowledged (dashboard bell)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Location {
  id              Int       @id @default(autoincrement())
  sectionTitle    String   @default("فروعنا")
  sectionDesc     String   @default("ابدأ رحلتك مع صناع الفرص...اعرف اقرب فرع إليك الآن")
  callTitle       String   @default("اتصل بنا")
  callDesc       String   @default("لا تتردد في التواصل")
  phone           String   @default("920032165")
  workingHours   String?   @db.LongText
  addresses       String?  @db.LongText
  heroTagline     String?  @db.Text
  logoUrl         String?
  mapImageUrl     String?
  companySubtitle String?  @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Homepage "Features" block (editable from dashboard)
model HomeFeatures {
  id               Int      @id @default(autoincrement())
  sectionTitle     String   @default("اكتشف قوة ميزاتنا")
  sectionSubtitle  String   @db.Text
  itemsJson        String   @db.LongText // [{ layout: compact|wide, title, description, imageUrl, sortOrder }]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// Homepage statistics row + "How it works" block
model HomeIntro {
  id           Int      @id @default(autoincrement())
  statsJson    String   @db.LongText // [{ value: "10+"|"+300"|"2K", label, sortOrder }]
  howHeading   String   @db.Text
  howBody      String   @db.Text
  howVideoUrl  String?
  howPosterUrl String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Homepage "طريقة عملنا" steps + consultant (CEO) card
model HomeWorkConsultant {
  id                  Int      @id @default(autoincrement())
  workTitle           String   @db.Text
  workSubtitle        String   @db.Text
  step1Text           String   @db.Text
  step2Text           String   @db.Text
  step3Text           String   @db.Text
  consultantRole      String   @default("CEO")
  consultantHeading   String   @db.Text
  consultantBio       String   @db.LongText
  consultantImageUrl  String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// روابط السوشيال في الفوتر (صف واحد، يُحدَّث من لوحة التحكم)
model FooterSocial {
  id        Int      @id @default(autoincrement())
  twitter   String?  @db.VarChar(2000)
  instagram String?  @db.VarChar(2000)
  youtube   String?  @db.VarChar(2000)
  facebook  String?  @db.VarChar(2000)
  linkedin  String?  @db.VarChar(2000)
  tiktok    String?  @db.VarChar(2000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}